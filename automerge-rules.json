{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "automergeSchedule": [
    "* 0-4,22-23 * * 1-5",
    "* * * * 0,6"
  ],
  "packageRules": [
    {
      "matchPackageNames": ["@joltdesign/scripts", "jolt-wp-updater"],
      "automerge": true
    },
    {
      "matchPackageNames": ["yarn", "yarnpkg/berry", "@yarnpkg/cli"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "matchPackageNames": ["node", "nodejs", "nodejs/node"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "matchPackageNames": ["@types/**"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    }
  ]
}
